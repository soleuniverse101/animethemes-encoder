{
  "name": "animethemes-encoder",
  "version": "0.1.0",
  "author": "soleuniverse",
  "description": "A helper tool to streamline the encoding process of AnimeThemes.moe",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite dev",
    "build": "vite build",
    "preview": "vite preview",
    "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
    "tauri": "tauri",
    "lint": "prettier --check .",
    "format": "prettier --write . && cargo fmt --manifest-path src-tauri/Cargo.toml",
    "ci:version": "changeset version && node scripts/cargo-version.js"
  },
  "license": "MIT",
  "dependencies": {
    "@tauri-apps/api": "^2.11.0",
    "@tauri-apps/plugin-dialog": "~2.7.1",
    "@tauri-apps/plugin-opener": "^2.5.4",
    "hotkeys-js": "^4.0.4",
    "tauri-plugin-libmpv-api": "^0.3.2"
  },
  "devDependencies": {
    "@changesets/cli": "^2.31.0",
    "@iconify/svelte": "^5.2.1",
    "@sveltejs/adapter-static": "^3.0.10",
    "@sveltejs/kit": "^2.60.1",
    "@sveltejs/vite-plugin-svelte": "^5.1.1",
    "@tailwindcss/vite": "^4.3.0",
    "@tauri-apps/cli": "^2.11.2",
    "prettier": "^3.8.3",
    "prettier-plugin-jsdoc": "^1.8.0",
    "prettier-plugin-merge": "^0.10.1",
    "prettier-plugin-organize-imports": "^4.3.0",
    "prettier-plugin-svelte": "^3.5.1",
    "prettier-plugin-tailwindcss": "^0.7.4",
    "svelte": "^5.55.9",
    "svelte-check": "^4.4.8",
    "tailwindcss": "^4.3.0",
    "typescript": "~5.6.3",
    "vite": "^6.4.2"
  },
  "packageManager": "pnpm@11.4.0+sha512.f0febc7e37552ab485494a914241b338e0b3580b93d54ce31f00933015880863129038a1b4ae4e414a0ee63ac35bf21197e990172c4a68256450b5636310968f"

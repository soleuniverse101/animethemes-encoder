{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "animethemes-encoder",
  "version": "0.1.4",
  "identifier": "me.soleuniverse.animethemes-encoder",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../build"
  },
  "app": {
    "windows": [
      {
        "title": "animethemes-encoder",
        "width": 800,
        "height": 600
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "msi",
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": ["lib/**/*"]
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEVDMjVENzQ1NTgyQzdFNzkKUldSNWZpeFlSZGNsN0t0MmplUmNoWjhMMGhDZ09aUnhxUHd3aUpFTzJHaEZvL29ZQitIMzA2dDkK",
      "endpoints": [
        "https://github.com/soleuniverse101/animethemes-encoder/releases/latest/download/latest.json"
      ]
    }
  }
}
